# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection details. All variables marked (required) must be set.
LOG_DB_HOST=localhost          # (required) PostgreSQL host
LOG_DB_PORT=5432               # (optional) PostgreSQL port — default 5432
LOG_DB_USER=youruser           # (required) Database username
LOG_DB_PASSWORD=yourpassword   # (required) Database password
LOG_DB_NAME=ologs              # (required) Database name

# ── Docker / Deployment (optional) ───────────────────────────────────────────
# Used by docker-compose.yml. Leave commented out to use defaults.
# REGISTRY_URL=your-registry.example.com/logstorageapi
# IMAGE_TAG=latest
# APP_PORT=8810
